# NDA / local-only content — never tracked
restricted/*
!restricted/.env.example

# Machine-specific MCP config (rhai-tracker path is per-machine; regenerated
# by hub.doctor / scripts/doctor.sh)
.mcp.json

# memory scratch tier (Claude auto-memory redirect target)
memory/.scratch/

# per-machine harness settings
.claude/settings.local.json

# agent worktrees + subagent-driven-development scratch (never tracked;
# protects skills' `git add -A` from picking up embedded worktree gitlinks)
.claude/worktrees/
.superpowers/

# ephemeral skill state
tmp/

# meeting transcripts anywhere
**/transcripts/

# python
__pycache__/
.pytest_cache/
*.pyc
