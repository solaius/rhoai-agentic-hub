# NDA content — tracked but encrypted via git-crypt (see docs/setup.md)
# restricted/.env.example stays plaintext (.gitattributes exclusion)

# Machine-specific MCP config (rhai-tracker path is per-machine; regenerated
# by hub.doctor / scripts/doctor.sh)
.mcp.json

# Cursor MCP config (secrets in env values, same as .mcp.json; regenerated
# by hub.doctor / scripts/doctor.sh)
.cursor/mcp.json

# memory scratch tier (Claude auto-memory redirect target)
memory/.scratch/

# per-machine harness settings
.claude/settings.local.json

# agent worktrees + subagent-driven-development scratch (never tracked;
# protects skills' `git add -A` from picking up embedded worktree gitlinks)
.claude/worktrees/
.superpowers/

# ephemeral skill state
tmp/

# rfe-creator pipeline: fetched architecture/rubric context + vendored
# assess-rfe copies (regenerated by scripts/bootstrap-assess-rfe.sh and
# fetch-architecture-context.sh; local copies deliberately not tracked)
.context/
.claude/agents/rfe-scorer.md
.claude/skills/assess-rfe/
.claude/skills/export-rubric/

# meeting transcripts anywhere
**/transcripts/

# python
__pycache__/
.pytest_cache/
*.pyc
